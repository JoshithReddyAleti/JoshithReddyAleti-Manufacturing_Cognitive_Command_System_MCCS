# MCCS Real-Time Configuration
# ================================

# LLM - Google Gemini
GEMINI_API_KEY=  #your_GEMINI_api_key_here
LLM_MODEL=gemini-2.0-flash

# OpenWeather API (6.1)
OPENWEATHER_API_KEY= #your_OPENWEATHER_api_key_here

# FRED - Federal Reserve Economic Data (6.4)
FRED_API_KEY= #your_fred_api_key_here

# Finnhub - Stock Market Data
FINNHUB_API_KEY= #your_fINNHUB_api_key_here

# BLS - Bureau of Labor Statistics (6.6) - public API, no key required
# GDELT (6.3) - public API, no key required
# World Bank WITS (6.2) - public API, no key required
# US BTS (6.5) - public data, no key required
